{
  "name": "@mov-ai/mov-fe-lib-core",
  "version": "1.1.2-29",
  "description": "The Mov.AI's core frontend library.",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/mov-ai"
  },
  "main": "./dist/index.js",
  "scripts": {
    "test": "jest",
    "testDev": "jest --watchAll",
    "testStatic": "webpack --mode=development && echo 'Open browser at http://localhost:3030/test/index.html' && node test/server.js",
    "build": "webpack --mode=production",
    "buildDev": "webpack --mode=development --watch",
    "clean": "rm -r node_modules; rm package-lock.json"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MOV-AI/frontend-npm-lib-core.git"
  },
  "keywords": [
    "frontend",
    "core",
    "common",
    "utils"
  ],
  "author": "MOV.AI",
  "license": "ISC",
  "homepage": "https://github.com/MOV-AI/frontend-npm-lib-core/blob/main/README.md",
  "devDependencies": {
    "@babel/core": "^7.23.7",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-proposal-json-strings": "^7.18.6",
    "@babel/plugin-syntax-dynamic-import": "^7.8.3",
    "@babel/plugin-syntax-import-meta": "^7.10.4",
    "@babel/plugin-transform-runtime": "^7.23.7",
    "@babel/preset-env": "^7.23.8",
    "@babel/preset-react": "^7.23.3",
    "@types/jest": "29.5.11",
    "@types/lodash": "^4.14.182",
    "@types/node": "^20.11.0",
    "@types/roslib": "^1.1.8",
    "babel-jest": "^29.7.0",
    "babel-loader": "^9.1.3",
    "express": "^4.18.1",
    "http-proxy-middleware": "^2.0.6",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "url-loader": "^4.1.1",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-node-externals": "^3.0.0"
  },
  "dependencies": {
    "@babel/runtime": "^7.23.8",
    "fast-equals": "^5.0.1",
    "jwt-decode": "^3.1.2",
    "lodash": "^4.17.21",
    "monet": "^0.9.2",
    "roslib": "^1.3.0",
    "rxjs": "^7.3.0"
  },
  "files": [
    "dist",
    "resources"
  ],
  "typesVersions": {
    "*": {
      "api": [
        "dist/src/api/index.d.ts"
      ],
      "models": [
        "dist/src/models/index.d.ts"
      ]
    }
