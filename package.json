{
  "name": "@mov-ai/mov-fe-lib-core",
  "version": "1.1.2-28",
  "description": "The Mov.AI's core frontend library.",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/mov-ai"
  },
  "main": "./dist/",
  "type": "commonjs",
  "exports": {
    ".": {
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json",
    "./*": "./dist/*"
  },
   "@tty-pt/scripts": {
     "entry": "./src/index.ts",
     "development": true,
     "library": true
   },
  "scripts": {
    "test": "./node_modules/.bin/scripts test",
    "lint": "./node_modules/.bin/scripts lint",
    "testDev": "./node_modules/.bin/scripts watch",
    "testStatic": "./node_modules/.bin/scripts serve",
    "build": "./node_modules/.bin/scripts build",
    "buildDev": "./node_modules/.bin/scripts watch",
    "clean": "rm -r node_modules; rm package-lock.json"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MOV-AI/frontend-npm-lib-core.git"
  },
  "keywords": [
    "frontend",
    "core",
    "common",
    "utils"
  ],
  "author": "MOV.AI",
  "license": "ISC",
  "homepage": "https://github.com/MOV-AI/frontend-npm-lib-core/blob/main/README.md",
  "devDependencies": {
    "@types/lodash": "^4.14.182",
    "@types/jest": "27.5.1",
    "@types/node": "^17.0.30",
    "@types/roslib": "^1.1.8",
    "babel-jest": "^28.1.0",
    "babel-loader": "^8.2.2",
    "express": "^4.18.1",
    "http-proxy-middleware": "^2.0.6",
    "jest": "^28.1.0",
    "ts-loader": "^9.3.0",
    "ts-jest": "^28.0.3",
    "typescript": "^4.7.2",
    "url-loader": "^4.1.1",
    "webpack": "^5.53.0",
    "webpack-cli": "^4.8.0",
    "webpack-node-externals": "^3.0.0"
  },
  "dependencies": {
    "@babel/runtime": "^7.15.4",
    "fast-equals": "^5.0.1",
    "http-proxy-middleware": "^2.0.6",
    "jest": "^28.1.0"
  },
  "dependencies": {
    "@types/jest": "27.5.1",
    "@types/roslib": "^1.1.8",
    "@tty-pt/scripts": "workspace:^0.1.2",
    "deep-equal": "^2.2.0",
    "jwt-decode": "^3.1.2",
    "lodash": "^4.17.21",
    "monet": "^0.9.2",
    "roslib": "^1.3.0",
    "rxjs": "^7.3.0",
    "ts-jest": "^28.0.3"
  },
  "files": [
    "dist",
    "resources"
  ],
  "typesVersions": {
    "*": {
      "api": [
        "dist/src/api/index.d.ts"
      ],
      "models": [
        "dist/src/models/index.d.ts"
      ]
    }
  }
}
